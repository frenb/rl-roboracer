RUN echo "deb http://packages.ros.org/ros/ubuntu focal main" | tee /etc/apt/sources.list.d/ros-focal.list
RUN apt-key adv --keyserver 'hkp://keyserver.ubuntu.com:80' --recv-key C1CF6E31E6BADE8868B172B4F42ED6FBAB17C654
RUN apt-get update && apt-get install -y vim iputils-ping net-tools python3-pip 
ENV DEBIAN_FRONTEND noninteractive
RUN apt-get install -y ros-noetic-robot-state-publisher 
RUN apt-get install -y ros-noetic-moveit 
RUN apt-get install -y ros-noetic-rosbridge-suite 
RUN apt-get install -y ros-noetic-joy 
RUN apt-get install -y ros-noetic-ros-control 
RUN apt-get install -y ros-noetic-ros-controllers 
RUN apt-get install -y dos2unix python3-venv
RUN apt-get reinstall -y lsb-release
RUN apt-get install apt-transport-https curl gnupg -y

RUN ln -s /usr/bin/python3 /usr/bin/python
RUN python -m pip install grpcio google-api-python-client
RUN pip3 install tensorboard
RUN pip3 install -U tensorboard-plugin-profile
RUN pip3 install pymongo
RUN pip3 install numpy==1.23.1
RUN pip3 install scipy
RUN pip install --upgrade pip
ENV PYTHON_WORKSPACE=/python_ws
ENV ROS_WORKSPACE=/catkin_ws

COPY ./Docker/pick_and_place/python_ws $PYTHON_WORKSPACE

COPY ./Docker/pick_and_place/ROS/src/moveit_msgs $ROS_WORKSPACE/src/moveit_msgs
COPY ./Docker/pick_and_place/ROS/src/niryo_moveit $ROS_WORKSPACE/src/niryo_moveit
COPY ./Docker/pick_and_place/ROS/src/niryo_one_ros $ROS_WORKSPACE/src/niryo_one_ros
COPY ./Docker/pick_and_place/ROS/src/niryo_one_urdf $ROS_WORKSPACE/src/niryo_one_urdf
COPY ./Docker/pick_and_place/ROS/src/ros_tcp_endpoint $ROS_WORKSPACE/src/ros_tcp_endpoint
COPY ./Docker/pick_and_place/ROS/src/virtual_endpoint $ROS_WORKSPACE/src/virtual_endpoint
COPY ./Docker/pick_and_place/ROS/src/rospy_message_converter $ROS_WORKSPACE/src/rospy_message_converter
COPY ./Docker/pick_and_place/ROS/src/start.sh $ROS_WORKSPACE/src/start.sh
COPY ./Docker/pick_and_place/ROS/src/ros_log_tail_server.py $ROS_WORKSPACE/src/ros_log_tail_server.py
COPY ./Docker/pick_and_place/ROS/src/python_workspace_server.py $ROS_WORKSPACE/src/python_workspace_server.py
COPY ./Docker/pick_and_place/python_ws $PYTHON_WORKSPACE

COPY ./Frontend/public/workspaces/python/robotaxi.py $PYTHON_WORKSPACE/src/robotaxi.py
COPY ./Frontend/public/workspaces/python/api.py $PYTHON_WORKSPACE/src/api.py

COPY ./Docker/pick_and_place/docker/set-up-workspace /setup.sh
COPY ./Docker/pick_and_place/docker/tutorial /

RUN /bin/bash -c "find $ROS_WORKSPACE -type f -print0 | xargs -0 dos2unix"
RUN dos2unix /tutorial && dos2unix /setup.sh && chmod +x /setup.sh && /setup.sh && rm /setup.sh
#RUN /bin/bash -c "cd $PYTHON_WORKSPACE &&  python3 -m venv --system-site-packages ./venv && source ./venv/bin/activate && pip install -r requirements.txt && deactivate"
RUN /bin/bash -c "cd /python_ws && pip install -r requirements.txt"
