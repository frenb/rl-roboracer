  script(src='/javascripts/editors.js')
  body
    //div(id="wrapper")
    nav.nav
      ul.nav__menu
        li.nav__menu-item
          a(onclick="saveEditors()") Save
        li.nav__menu-item
          a(onclick="runProgram()") &#9658;
        li.nav__menu-item
          a(onclick="stopProgram()") Stop
        li.nav__menu-item
          a(onclick="reset()") Reset
        li.nav__menu-item
          a(onclick="alert('save model')") Save Model
        li.nav__menu-item
          a(onclick="alert('load model')") Load Model
        li.nav__menu-item
          a Workspace
          ul(class='nav__submenu' id='workspaces_submenu')
            //li.nav__submenu-item 
            //  a Pick &amp; Place
            //li.nav__submenu-item 
            //  a Pole &amp; Cart TF
            //li.nav__submenu-item 
            //  a Pole &amp; Cart Python
            //li.nav__submenu-item 
            //  a Find &amp; Pick 
      //- ul(class="nav")
      //-   li(onclick="saveEditors()") Save
      //-   li(onclick="runProgram()") &#9658;
      //-   li(onclick="stopProgram()") Stop
      //-   li(onclick="reset()") Reset
    div(id="golden_layout")
    script(src='/javascripts/goldenlayout.js')
    script.
        function reset() {
          window.overhead_sequence = 0;
          api.doReset();
        }
    // Configure socket to receive ROS Log.
    script.
        var ros_log_text = "";
        var ansi_up = new AnsiUp;
        socket.emit('ros_log');
        socket.on('ros_log', function(data) {
            ros_log_text += data.data;
            if (window.ros_log_div) {
              var div = document.getElementById(window.ros_log_div);
              div.innerHTML = '<pre>' + ansi_up.ansi_to_html(ros_log_text) + '</pre>';
              var parent_content = div.parentElement;
              parent_content.scrollTop = parent_content.scrollHeight;
            }
        });
    // Load list of workspaces.
    script.
        populateWorkspaces();
    // Support for ctrl-s save
    script.
        document.addEventListener("keydown", function(e) {
          if ((window.navigator.platform.match("Mac") ? e.metaKey : e.ctrlKey)
            && e.keyCode == 83) {
              e.preventDefault();
              saveEditors()
              // Process the event here (such as click on submit button)
            }
        }, false);
    // switch workspace with ctl-x
    script.
        document.addEventListener("keydown", function(e) {
          if ((window.navigator.platform.match("Mac") ? e.metaKey : e.ctrlKey)
            && e.keyCode == 88) {
              e.preventDefault();
              // Process the event here (such as click on submit button)
              wsList = ["Pick & Place", "Pole & Cart TF", "Pole & Cart Python", "Find & Pick"];
              randomIndex = Math.floor(Math.random() * (wsList.length-1));
              switchWorkspace(wsList[randomIndex]);
            }
        }, false);


